<!DOCTYPE html>
<html lang="en">

<head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>Wanderlust</title>
</head>

<body>

      <h3>Create a New Listing</h3>

      <form method="POST" action="/listings">

            <input name="listing[title]" placeholder="Enter the Title" value="<%= listing ? listing.title : '' %>">
            <br><br />

            <textarea name="listing[description]"
                  placeholder="Enter the Description"><%= listing ? listing.description : '' %></textarea>
            <br><br />

            <input name="listing[image]" placeholder="Enter Image URL/Link" type="text"
                  value="<%= listing ? listing.image : '' %>">
            <br><br />

            <input name="listing[price]" placeholder="Enter the Price" value="<%= listing ? listing.price : '' %>">
            <br><br />

            <input name="listing[location]" placeholder="Enter the Location"
                  value="<%= listing ? listing.location : '' %>">
            <br><br />

            <input name="listing[country]" placeholder="Enter the Country"
                  value="<%= listing ? listing.country : '' %>">
            <br><br />

            <button type="submit">Update Listing</button>

      </form>

</body>

</html>