<!DOCTYPE html>
<html lang="en">

<head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>Wanderlust</title>
</head>

<body>

      <h3>Edit the existing Listing</h3>

      <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">

            <input name="listing[title]" value="<%= listing ? listing.title : '' %>" type="text">
            <br><br />

            <textarea name="listing[description]"><%= listing ? listing.description : '' %></textarea>
            <br><br />

            <input name="listing[image]" type="text" value="<%= listing ? listing.image : '' %>">
            <br><br />

            <input name="listing[price]" value="<%= listing ? listing.price : '' %>">
            <br><br />

            <input name="listing[location]" value="<%= listing ? listing.location : '' %>">
            <br><br />

            <input name="listing[country]" value="<%= listing ? listing.country : '' %>">
            <br><br />

            <button type="submit">Update Listing</button>

      </form>

</body>

</html>