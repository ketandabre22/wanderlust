<% layout("layouts/boilerplate") %>

      <body>
            <h3>All Listings </h3>
            <form method="GET" action="/listings/new">
                  <button type="submit">Create New Listing</button>
            </form>
            <ul>
                  <% allListings.forEach(function(listing) { %>
                        <li> <a href="/listings/<%= listing._id %>">
                                    <%= listing.title %>
                              </a> </li>
                        <% }); %>
            </ul>
      </body>